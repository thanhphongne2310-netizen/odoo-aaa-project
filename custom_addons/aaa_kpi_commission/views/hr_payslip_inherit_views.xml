<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_inherit_approval" model="ir.ui.view">
        </record>

    <record id="view_hr_payslip_tree_inherit_approval" model="ir.ui.view">
        <field name="name">hr.payslip.tree.inherit.approval</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="om_hr_payroll.view_hr_payslip_tree"/> 
        
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                 <header>
                    <button name="action_director_approve" string="Giám đốc Duyệt Nhanh" type="object" class="btn-success" groups="base.group_erp_manager"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>