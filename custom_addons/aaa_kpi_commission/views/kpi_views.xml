<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_commission_form" model="ir.ui.view">
        <field name="name">kpi.commission.form</field>
        <field name="model">kpi.commission</field>
        <field name="arch" type="xml">
            <form string="Phiếu KPI">
                
                <header>
                    <button name="action_submit" string="Gửi duyệt" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Phê duyệt" type="object" class="oe_highlight" invisible="state != 'waiting'"/>
                    <button name="action_reject" string="Từ chối" type="object" invisible="state != 'waiting'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting,approved"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="name" placeholder="VD: 03/2026"/>
                        </group>
                        <group>
                            <field name="actual_revenue"/>
                            <field name="target_revenue"/>
                            <field name="commission_rate"/>
                            <field name="commission_amount"/>
                        </group>
                    </group>
                </sheet> 

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
                
            </form>
        </field>
    </record>

    <record id="view_kpi_commission_tree" model="ir.ui.view">
        <field name="name">kpi.commission.tree</field>
        <field name="model">kpi.commission</field>
        <field name="arch" type="xml">
            <tree string="Danh sách KPI">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="actual_revenue"/>
                <field name="commission_rate"/>
                <field name="commission_amount"/>
            </tree>
        </field>
    </record>

    <record id="action_kpi_commission" model="ir.actions.act_window">
        <field name="name">Quản lý Doanh thu KPI</field>
        <field name="res_model">kpi.commission</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_kpi_root" name="KPI &amp; Hoa hồng" sequence="10"/>
    <menuitem id="menu_kpi_commission" name="Báo cáo Doanh thu" parent="menu_kpi_root" action="action_kpi_commission" sequence="1"/>
</odoo>