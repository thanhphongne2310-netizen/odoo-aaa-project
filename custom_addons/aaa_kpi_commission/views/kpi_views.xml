<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_record_form" model="ir.ui.view">
        <field name="name">kpi.record.form</field>
        <field name="model">kpi.record</field> 
        <field name="arch" type="xml">
            <form string="Phiếu KPI">
                <header>
                    <button name="action_submit" string="Gửi duyệt" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    
                    <button name="action_approve" string="Phê duyệt" type="object" class="oe_highlight" invisible="state != 'waiting'" groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Từ chối" type="object" invisible="state != 'waiting'" groups="hr.group_hr_manager"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting,approved"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="name" placeholder="VD: 03/2026"/>
                        </group>
                        <group>
                            <field name="target_revenue"/>
                            <field name="actual_revenue" readonly="1" force_save="1"/>
                            <field name="kpi_percentage" widget="progressbar"/>
                            <field name="total_commission" readonly="1" force_save="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Danh sách Hợp đồng bảo hiểm">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="contract_number"/>
                                    <field name="product_code"/>
                                    <field name="revenue" sum="Tổng phí"/>
                                    <field name="commission_rate"/>
                                    <field name="commission_amount" sum="Tổng HH"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet> 

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_kpi_record_tree" model="ir.ui.view">
        <field name="name">kpi.record.tree</field>
        <field name="model">kpi.record</field> 
        <field name="arch" type="xml">
            <tree string="Danh sách KPI" default_order="id desc">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="target_revenue" optional="show"/>
                <field name="actual_revenue"/>
                <field name="kpi_percentage" widget="progressbar"/>
                <field name="total_commission"/>
                <field name="state" widget="badge" 
                       decoration-muted="state == 'draft'"
                       decoration-warning="state == 'waiting'" 
                       decoration-success="state == 'approved'"/>
            </tree>
        </field>
    </record>

    <record id="action_kpi_record" model="ir.actions.act_window">
        <field name="name">Quản lý Doanh thu KPI</field>
        <field name="res_model">kpi.record</field> 
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_kpi_root" name="Hoa Hồng" sequence="10"/>
    <menuitem id="menu_kpi_commission" name="Báo cáo Doanh thu" parent="menu_kpi_root" action="action_kpi_record" sequence="1"/>
</odoo>
